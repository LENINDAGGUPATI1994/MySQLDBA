
--- To know year wise records count on the table

SELECT 
    YEAR(insert_date) AS Year,
    COUNT(*) AS RecordCount
FROM 
    ods_pms_reservations
GROUP BY 
    YEAR(insert_date)
ORDER BY 
    YEAR(insert_date);

--- To know Record Date frequency
Select MIN (update_date) as RecordStart,
MAX (update_date) as RecordEnd
FROM stage_ors_membership_transactions

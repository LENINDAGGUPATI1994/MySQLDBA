CREATE INDEX IX_DB_Growth_DateTime ON [dbo].[DB_Growth] (DateTime);
CREATE INDEX IX_DB_Growth_DBName_DateTime ON [dbo].[DB_Growth] (DBName, DateTime);
CREATE INDEX IX_DB_Growth_RecordDate ON [dbo].[DB_Growth] (RecordDate);


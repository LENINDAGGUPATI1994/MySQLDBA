-- Table to track overall database growth
CREATE TABLE [dbo].[DB_Growth] (
    [ID] INT IDENTITY(1,1) PRIMARY KEY,
    [DBName] NVARCHAR(128) NOT NULL,
    [Total_Size_MB] DECIMAL(20,2) NOT NULL,
    [Data_Size_MB] DECIMAL(20,2) NOT NULL,
    [Index_Size_MB] DECIMAL(20,2) NOT NULL,
    [Unused_Size_MB] DECIMAL(20,2) NOT NULL,
